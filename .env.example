# Application Configuration
NODE_ENV=development

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_API_URL=https://api.telegram.org

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6378
REDIS_DATABASE=0

# MongoDB Configuration
# Option 1: Use full connection URI
MONGODB_URI=mongodb://localhost:27017/botbot

# Option 2: Use individual connection parameters (if MONGODB_URI is not set)
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_DATABASE=botbot

# AI Configuration
# Options: 'gemini' or 'fuse'
# - gemini: Uses Google Gemini 2.0 Flash Exp
# - fuse: Uses Claude Opus 4.5 via Fuse API
AI_PROVIDER=gemini
# For Gemini: Use Google AI API key
# For Fuse: Use Fuse API key (format: fuse_xxxxx)
AI_API_KEY=your_api_key_here
# Optional: Fuse API URL (only used when AI_PROVIDER=fuse)
# Default: https://api.fuseapi.app/v1/chat/completions
FUSE_API_URL=https://api.fuseapi.app/v1/chat/completions

# Timezone Configuration
TIMEZONE=Asia/Ho_Chi_Minh
